generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum InputType {
  INT
  ARRAY
  STRING
  BOOLEAN
}

enum ChallengeType {
  SCHEDULED
  STATIC
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ReportType {
  SPAM_OR_ADVERTISING
  HARASSMENT_OR_ABUSE
  INAPPROPRIATE_CONTENT
  PLAGIARISM
  OTHER
}

model User {
  userId              Int       @id @default(autoincrement())
  full_name           String
  username            String    @unique
  email               String    @unique
  password_hash       String?
  has_password        Boolean   @default(false)
  auth_provider       String?
  github_id           String?
  github_access_token String?
  google_id           String?
  profile_pic_url     String?
  resetToken          String?   @unique
  resetTokenExpiry    DateTime?
  bio                 String?
  role                Role      @default(USER)
  total_points        Int       @default(0)

  // Relations
  submissions     Submission[]
  problemStatuses UserProblemStatus[]
  discussions     Discussion[] // Added link to discussions
  discussionVotes DiscussionUpvote[] // Added link to track upvotes

  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  discussionReports DiscussionReport[]

  @@map("users")
}

model Problem {
  problemId    Int       @id @default(autoincrement())
  title        String
  content      String    @db.Text
  difficulty   String // EASY, MEDIUM, HARD
  points       Int       @default(50)
  functionName String    @default("solution")
  starterCode  Json
  inputType    InputType @default(ARRAY)
  timeLimit    Float     @default(1.0)
  memoryLimit  Int       @default(128)

  // Relations
  categories   Category[]
  testCases    TestCase[]
  submissions  Submission[]
  userStatuses UserProblemStatus[]
  challenges   ChallengeProblem[]
  discussions  Discussion[] // Added link to discussions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("problems")
}

// --- NEW DISCUSSION MODELS ---

model Discussion {
  id       String  @id @default(cuid())
  title    String? // Only for the main post
  content  String  @db.Text
  language String? // e.g., "cpp", "python"

  // Relations to User and Problem (IDs changed to Int to match parents)
  userId Int
  user   User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  problemId Int
  problem   Problem @relation(fields: [problemId], references: [problemId], onDelete: Cascade)

  // Self-relation for nested replies
  parentId String?
  parent   Discussion?  @relation("DiscussionToDiscussion", fields: [parentId], references: [id])
  replies  Discussion[] @relation("DiscussionToDiscussion")

  // Upvotes handling
  upvotes      Int                @default(0)
  upvoteTracks DiscussionUpvote[]
  isBlocked    Boolean            @default(false)
  reportCount  Int                @default(0)
  reports      DiscussionReport[]

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@map("discussions")
}

model DiscussionUpvote {
  id           Int    @id @default(autoincrement())
  userId       Int
  discussionId String

  user       User       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@unique([userId, discussionId]) // Ensures one upvote per user per comment
  @@map("discussion_upvotes")
}

model DiscussionReport {
  id           Int      @id @default(autoincrement())
  userId       Int
  discussionId String
  
  // The category (e.g., SPAM, HARASSMENT)
  reportType   ReportType   @default(OTHER)
  
  //The specific user input explanation
  details      String?  @db.Text 

  user       User       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, discussionId]) 
  @@map("discussion_reports")
}

// --- REMAINING MODELS (Category, TestCase, Submission, etc.) ---

model Category {
  categoryId  Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  problems    Problem[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model TestCase {
  id             Int     @id @default(autoincrement())
  input          String  @db.Text
  expectedOutput String  @db.Text
  isSample       Boolean @default(false)
  problemId      Int
  problem        Problem @relation(fields: [problemId], references: [problemId], onDelete: Cascade)

  @@map("test_cases")
}

model Submission {
  id          String   @id @default(uuid())
  problemId   Int
  userId      Int
  challengeId Int?
  code        String   @db.Text
  languageId  Int
  status      String
  totalPassed Int      @default(0)
  totalCases  Int      @default(0)
  memory      Int?
  time        Float?
  token       String?  @unique
  failMessage String?
  createdAt   DateTime @default(now())
  problem     Problem  @relation(fields: [problemId], references: [problemId])
  user        User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("submissions")
}

model UserProblemStatus {
  id        Int     @id @default(autoincrement())
  userId    Int
  problemId Int
  status    String
  user      User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [problemId])

  @@unique([userId, problemId])
  @@map("user_problem_status")
}

model Challenge {
  challengeId Int                 @id @default(autoincrement())
  title       String
  slug        String              @unique
  description String?             @db.Text
  bannerUrl   String?
  type        ChallengeType       @default(SCHEDULED) // Added static vs scheduled
  difficulty  ChallengeDifficulty @default(MEDIUM)
  points      Int                 @default(100)
  isPublic    Boolean             @default(false)
  startTime   DateTime?
  endTime     DateTime?
  problems    ChallengeProblem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("challenges")
}

model ChallengeProblem {
  challenge   Challenge @relation(fields: [challengeId], references: [challengeId], onDelete: Cascade)
  challengeId Int
  problem     Problem   @relation(fields: [problemId], references: [problemId], onDelete: Cascade)
  problemId   Int
  order       Int       @default(0)

  @@id([challengeId, problemId])
  @@map("challenge_problems")
}
